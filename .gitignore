cat > .gitignore << 'EOF'
# Dependencies
node_modules/
.prisma/

# Env / secrets
.env
.env.local
.env.*.local
*.key
*.pem

# Build / dist
dist/
build/
.status

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*

# Prisma (if you don't want DB files tracked)
prisma/*.db
EOF